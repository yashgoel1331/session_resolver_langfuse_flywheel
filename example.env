ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8090

# Internal API auth (required for all environments)
# SESSION_FINDER_API_KEY=

# Langfuse — dev (separate host + project keys)
# LANGFUSE_DEV_PUBLIC_KEY=pk-lf-...
# LANGFUSE_DEV_SECRET_KEY=sk-lf-...
# LANGFUSE_DEV_BASE_URL=https://langfuse.dev.amulai.in

# Langfuse — prod (separate host + project keys)
# LANGFUSE_PROD_PUBLIC_KEY=pk-lf-...
# LANGFUSE_PROD_SECRET_KEY=sk-lf-...
# LANGFUSE_PROD_BASE_URL=https://langfuse.prod.amulai.in

# Langfuse API timeout in seconds (trace scans with IO can be slow on self-hosted)
# LANGFUSE_TIMEOUT_SECONDS=60

# Vision extraction (screenshots) — same key as chat service
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_VISION_MODEL=gpt-4o
